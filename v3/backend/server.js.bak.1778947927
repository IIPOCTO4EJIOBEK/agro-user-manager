#!/usr/bin/env node
/**
 * AD Ultimate Manager V3.0
 * =========================
 * Changes from V2.6:
 * - Async ldapjs instead of execSync (non-blocking event loop)
 * - File-based session store (survives restarts)
 * - Input validation (express-validator)
 * - SQLite audit trail
 * - Group operations (bulk enable/disable/move)
 * - Security: chmod 600, escapeDN, escapeHtml, helmet, rate-limit, CORS
 */

const express = require('express');
const cors = require('cors');
const session = require('express-session');
// FileStore removed for stability
const FileStore = null;
const helmet = require('helmet');
const rateLimit = require('express-rate-limit');
const { body, validationResult } = require('express-validator');
const { execSync } = require('child_process');
const ldap = require('ldapjs');
const fs = require('fs');
const path = require('path');
const iconv = require('iconv-lite');
const { parse } = require('csv-parse/sync');
const Database = require('better-sqlite3');

const app = express();
const PORT = 4003; // V3 runs on different port

// --- Security ---
app.use(helmet({ contentSecurityPolicy: false }));
app.use(cors({ origin: ['http://10.1.17.128', 'http://10.1.17.128:8080', 'http://10.1.17.128:80', 'http://10.1.17.128:8089', 'http://localhost:8080', 'http://localhost:8089', 'http://localhost'], credentials: true }));
app.use(express.json({ limit: '10mb' }));
app.use(express.static('/var/www/agro-user-v2'));

app.use(session({
    secret: process.env.SESSION_SECRET || require('crypto').randomBytes(32).toString('hex'),
    resave: false, saveUninitialized: false,
    cookie: { secure: false, httpOnly: true, sameSite: 'lax', maxAge: 8 * 60 * 60 * 1000 }
}));

const loginLimiter = rateLimit({ windowMs: 15 * 60 * 1000, max: 10, message: { error: 'Too many login attempts' } });
app.use('/auth/login', loginLimiter);

// --- Constants ---
const BASE_DN = 'DC=rusagroeco,DC=ru';
const ENV = { ...process.env, LDAPTLS_REQCERT: 'never' };

// --- SQLite Audit ---
const AUDIT_DB = '/opt/agro-user-manager-v3/data/audit.db';
const audit = new Database(AUDIT_DB);
audit.exec(`CREATE TABLE IF NOT EXISTS audit (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    ts TEXT DEFAULT (datetime('now')),
    operator TEXT,
    action TEXT,
    target TEXT,
    details TEXT
)`);
audit.pragma('journal_mode=WAL');

function auditLog(operator, action, target, details) {
    try { audit.prepare('INSERT INTO audit (operator, action, target, details) VALUES (?,?,?,?)').run(operator, action, target, JSON.stringify(details)); } catch(e) {}
}

function log(m) {
    const msg = new Date().toISOString() + ' [INFO] ' + m + '\n';
    console.log(msg);
    try { fs.appendFileSync('/opt/agro-user-manager-v3/logs/app.log', msg); } catch (e) {}
}

// --- Utilities ---
function escapeDN(val) { return (val||'').replace(/[\\,"+<>;#=]/g, '\\$&'); }
function escapeHtml(val) { return (val||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function decode(s) { try { return Buffer.from(s, 'base64').toString('utf8'); } catch(e) { return s; } }

function sanitize(msg, pass) {
    if (!msg) return msg;
    let clean = msg;
    if (pass) {
        const escapedPass = pass.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        clean = clean.replace(new RegExp(escapedPass, 'g'), '********');
    }
    return clean.replace(/-w\s+"[^"]+"/g, '-w "********"').replace(/-w\s+'[^']+'/g, '-w "********"');
}

function toLdif(attr, val) {
    if (val === undefined || val === null) return '';
    const needsB64 = /[^\x00-\x7F]/.test(val);
    if (needsB64) return attr + ':: ' + Buffer.from(val).toString('base64');
    return attr + ': ' + val;
}

const ABBREV = [
    ['чрезвычайных ситуаций', 'ЧС'], ['Ростовской области', 'РО'], ['Республики Калмыкия', 'РК'],
    ['Республика Калмыкия', 'РК'], ['информационно-технологической', 'ИТ'],
    ['информационно-технологического', 'ИТ'], ['информационно-технологических', 'ИТ'],
    ['информационно-технологический', 'ИТ'], ['информационно-технологическая', 'ИТ'],
    ['информационно-технологические', 'ИТ'], ['информационно-технологическому', 'ИТ'],
    ['сельскохозяйствен', 'с/х'], ['недвижимым имуществом', 'недв.имуществом'],
    ['недвижимого имущества', 'недв.имущества'],
];
function abbrev(s) { for (const [f, t] of ABBREV) s = s.replace(f, t); return s; }

const tr = (t) => {
    if (!t) return '';
    const m = {'а':'a','б':'b','в':'v','г':'g','д':'d','е':'e','ё':'yo','ж':'zh','з':'z','и':'i','й':'y','к':'k','л':'l','м':'m','н':'n','о':'o','п':'p','р':'r','с':'s','т':'t','у':'u','ф':'f','х':'h','ц':'ts','ч':'ch','ш':'sh','щ':'shch','ъ':'','ы':'y','ь':'','э':'e','ю':'yu','я':'ya'};
    return t.toLowerCase().split('').map(c => m[c] || c).join('');
};

// --- Cache ---
let cache = { users: [], ous: [], depts: [], comps: [], titles: [], locations: [], offices: [], descriptions: [], assistants: [], dbStats: {}, syncing: false, lastUpdate: 0 };

// --- Auth ---
function isAuth(req, res, next) { if (req.session?.authenticated) return next(); res.status(401).send(); }

// --- Async AD Operations (replaces execSync) ---
function ldapSearch(adUrl, adUser, adPass, base, filter, attrs) {
    return new Promise((resolve, reject) => {
        const client = ldap.createClient({ url: adUrl, tlsOptions: { rejectUnauthorized: false } });
        const results = [];
        client.bind(adUser, adPass, (err) => {
            if (err) { client.destroy(); return reject(err); }
            const opts = { filter, scope: 'sub', attributes: attrs, paged: { pageSize: 1000 } };
            client.search(base, opts, (err2, res) => {
                if (err2) { client.destroy(); return reject(err2); }
                res.on('searchEntry', (entry) => {
                    const obj = { dn: entry.pojo?.objectName || '' };
                    for (const attr of entry.pojo?.attributes || []) {
                        obj[attr.type] = attr.values?.[0] || '';
                    }
                    results.push(obj);
                });
                res.on('end', () => { client.unbind(); resolve(results); });
                res.on('error', (e) => { client.destroy(); reject(e); });
            });
        });
    });
}

// === PowerShell AD API (replaces ldap CLI) ===

function psCall(action, data) {
    try {
        const dataJson = JSON.stringify(data);
        const out = execSync(`python3 /usr/local/bin/winrm_call.py ${action} '${dataJson.replace(/'/g, "'\''")}'`, 
            { encoding: 'utf-8', timeout: 30000, env: ENV });
        const result = JSON.parse(out.trim());
        if (!result.success) throw new Error(result.message || result.error || 'PS API error');
        return result;
    } catch(e) { throw new Error('PS call failed: ' + e.message); }
}

function ldapModify(adUrl, adUser, adPass, dn, changes) {
    const data = { dn };
    for (const c of changes) {
        const mod = c.modification;
        const key = mod.type || Object.keys(mod)[0];
        data[key] = mod.values ? mod.values[0] : Object.values(mod)[0];
    }
    if (data.manager === '') { data.manager = 'Вакансия'; } // clear manager
    // Abbreviate long fields
    for (const f of ['title', 'department', 'company']) {
        if (data[f]) { data[f] = abbrev(data[f]); if (data[f].length > 64) data[f] = data[f].substring(0, 64); }
    }
    return psCall('save-user', data);
}

function ldapAdd(adUrl, adUser, adPass, dn, entry) {
    const data = { ...entry };
    data.displayName = data.cn || entry.displayName;
    // Extract siteOU from DN
    const dnParts = dn.split(',');
    data.siteOU = dnParts.slice(1).join(',');
    data.addVpn = false;
    if (!data.password) { data.password = 'Agro' + Math.random().toString(36).substring(2, 10) + '!'; }
    const result = psCall('create-user', data);
    return { login: result.extra?.login, password: result.extra?.password || data.password, success: true };
}

// --- Async AD Data Loader ---
async function getADData(user, pass, adUrl) {
    cache.syncing = true;
    log('AD SCAN V3.0: Starting async crawl...');
    try {
        const attrs = ['sAMAccountName', 'mail', 'displayName', 'department', 'company', 'title', 'l', 'st', 'manager', 'info', 'telephoneNumber', 'mobile', 'homePhone', 'extensionAttribute1', 'extensionAttribute2', 'extensionAttribute3', 'assistant', 'userAccountControl', 'physicalDeliveryOfficeName', 'description', 'homeMDB', 'sn', 'givenName'];
        const users = await ldapSearch(adUrl, user, pass, BASE_DN, 
            '(&(objectClass=user)(objectCategory=person)(!(userAccountControl:1.2.840.113556.1.4.803:=2))(!(servicePrincipalName=*))(!(cn=*Mailbox*))(!(description=*service*)))',
            attrs);
        
        const ous = await ldapSearch(adUrl, user, pass, BASE_DN, '(objectClass=organizationalUnit)', ['ou', 'description']);
        
        const depts = new Set(), comps = new Set(), titles = new Set(), locs = new Set(), offices = new Set(), descs = new Set(), assts = new Set();
        const dbStats = { DB01:0, DB02:0, DB03:0, DB04:0, DB05:0, DB06:0, DB07:0, DB08:0, DB09:0, DB10:0, DB11:0, DB12:0 };
        
        for (const u of users) {
            if (u.department) depts.add(u.department);
            if (u.company) comps.add(u.company);
            if (u.title) titles.add(u.title);
            if (u.l) locs.add(u.l);
            if (u.physicalDeliveryOfficeName) offices.add(u.physicalDeliveryOfficeName);
            if (u.description) descs.add(u.description);
            if (u.assistant) assts.add(u.assistant);
            if (u.homeMDB) {
                const m = u.homeMDB.match(/CN=(DB\d{2})/i);
                if (m && dbStats[m[1]] !== undefined) dbStats[m[1]]++;
            }
        }
        
        const ouList = ous.map(o => ({
            name: o.ou || 'OU',
            dn: o.dn || '',
            desc: o.description || ''
        })).filter(o => o.dn);
        
        cache = {
            users: users.sort((a,b) => (a.displayName||'').localeCompare(b.displayName||'')),
            ous: ouList.sort((a,b) => a.dn.length - b.dn.length),
            depts: Array.from(depts).sort(),
            comps: Array.from(comps).sort(),
            titles: Array.from(titles).sort(),
            locations: Array.from(locs).sort(),
            offices: Array.from(offices).sort(),
            descriptions: Array.from(descs).sort(),
            assistants: Array.from(assts).sort(),
            dbStats, syncing: false, lastUpdate: Date.now()
        };
        log('AD SCAN V3.0: Finished. Users: ' + users.length + ', OUs: ' + ouList.length);
    } catch(e) {
        cache.syncing = false;
        log('AD SCAN ERROR V3.0: ' + sanitize(e.message, pass));
    }
}

// --- Routes ---
// Frontend served via express.static

app.post('/auth/login', (req, res) => {
    let { username, password, adIp } = req.body;
    const adUser = username.includes('@') ? username : username + '@rusagroeco.ru';
    const adUrl = 'ldaps://' + (adIp || '10.1.20.21');
    log(`LOGIN V3: ${adUser} on ${adUrl}`);
    const client = ldap.createClient({ url: adUrl, tlsOptions: { rejectUnauthorized: false } });
    client.bind(adUser, password, (err) => {
        if (err) {
            log('LOGIN ERROR V3: ' + err.message);
            client.destroy();
            return res.status(401).json({ error: sanitize(err.message, password) });
        }
        req.session.authenticated = true;
        req.session.adUser = adUser;
        req.session.adPass = password;
        req.session.adUrl = adUrl;
        res.json({ success: true });
        client.unbind();
        auditLog(username, 'LOGIN', 'session', { ip: req.ip });
        setTimeout(() => getADData(adUser, password, adUrl), 100);
    });
});

app.get('/auth/check', (req, res) => res.json({ authenticated: !!req.session?.authenticated }));
app.post('/auth/logout', (req, res) => { req.session.destroy(() => res.json({ success: true })); });
app.get('/api/data', isAuth, (req, res) => res.json(cache));

// --- Create User (async) ---
app.post('/api/create-user', isAuth, [
    body('displayName').trim().notEmpty().withMessage('ФИО обязательно'),
    body('siteOU').trim().notEmpty().withMessage('OU обязательно'),
], async (req, res) => {
    const errors = validationResult(req);
    if (!errors.isEmpty()) return res.status(400).json({ success: false, error: errors.array()[0].msg });
    
    const d = req.body;
    const sn = (d.sn || d.displayName.split(/\s+/)[0] || '').trim();
    const gn = (d.givenName || d.displayName.split(/\s+/)[1] || '').trim();
    const pn = (d.patronymic || d.displayName.split(/\s+/)[2] || '').trim();
    const trSn = tr(sn).replace(/^./, c => c.toUpperCase());
    const trGn = tr(gn).replace(/^./, c => c.toUpperCase());
    let login = (d.sam || (tr(sn) + '.' + (tr(gn)[0]||'') + (tr(pn)[0]||'')).toLowerCase().replace(/[^a-z0-9.]/g, '')).trim();
    
    const t64 = (s) => { s = abbrev(s || ''); return s.length > 64 ? s.substring(0, 64) : s; };
    
    const siteOU = d.siteOU.toUpperCase().startsWith('OU=USERS,') ? d.siteOU : `OU=Users,${d.siteOU}`;
    const userDN = `CN=${escapeDN(d.displayName)},${siteOU}`;
    const pass = d.password || `Agro${Math.random().toString(36).substring(2, 10)}!`;
    
    log(`CREATE V3: ${d.displayName} → ${userDN}`);
    
    try {
        const entry = {
            cn: d.displayName,
            displayName: d.displayName,
            sn: trSn,
            givenName: trGn,
            sAMAccountName: login,
            userPrincipalName: login + '@ahprostory.ru',
            objectClass: ['top', 'person', 'organizationalPerson', 'user'],
        };
        
        const attrMap = {
            title: t64(d.title), department: t64(d.department), company: t64(d.company),
            l: t64(d.l), st: t64(d.st), info: d.info, mail: d.mail || (login + '@ahprostory.ru'),
            telephoneNumber: d.telephoneNumber, mobile: d.mobile, homePhone: d.homePhone,
            extensionAttribute1: sn, extensionAttribute2: gn, extensionAttribute3: pn,
            assistant: d.assistant, description: d.description, physicalDeliveryOfficeName: t64(d.office)
        };
        for (const [k, v] of Object.entries(attrMap)) if (v) entry[k] = v;
        if (d.manager && !/^ваканс|^vacanc/i.test(d.manager)) {
            const mgrObj = cache.users.find(u => u.displayName === d.manager);
            if (mgrObj?.dn) entry.manager = mgrObj.dn;
        }
        
        entry.userAccountControl = '514';
        
        // Check login uniqueness
            const existingLogin = cache.users.find(u => u.sAMAccountName === login);
            if (existingLogin) {
                log('CREATE V3: Login ' + login + ' already exists');
                return res.status(400).json({ success: false, error: 'Логин ' + login + ' уже занят (пользователь: ' + (existingLogin.displayName||existingLogin.sAMAccountName) + ')' });
            }
            ldapAdd(req.session.adUrl, req.session.adUser, req.session.adPass, userDN, entry);
        
        // Enable + set password
        const pwdBase64 = Buffer.from(`"${pass}"`, 'utf16le').toString('base64');
        ldapModify(req.session.adUrl, req.session.adUser, req.session.adPass, userDN, [
            { operation: 'replace', modification: { unicodePwd: pwdBase64 } },
            { operation: 'replace', modification: { userAccountControl: '512' } }
        ]);
        
        // VPN group
        if (d.addVpn) {
            try {
                ldapModify(req.session.adUrl, req.session.adUser, req.session.adPass,
                    'CN=AD_VPN_Users,OU=Service Groups,OU=Groups,DC=rusagroeco,DC=ru',
                    [{ operation: 'add', modification: { member: userDN } }]);
            } catch(e) { log('VPN Error: ' + e.message); }
        }
        
        auditLog(req.session.adUser, 'CREATE', login, { displayName: d.displayName, dn: userDN });
        log(`CREATE V3 SUCCESS: ${login}`);
        res.json({ success: true, login, password: pass, email: d.mail || (login + '@ahprostory.ru'), displayName: d.displayName });
        
    } catch(e) {
        log('CREATE V3 ERROR: ' + sanitize(e.message, req.session.adPass));
        res.status(500).json({ success: false, error: sanitize(e.message, req.session.adPass) });
    }
});

// --- Save User (async) ---
app.post('/api/save-user', isAuth, async (req, res) => {
    const { dn, data } = req.body;
    if (!dn || !data) return res.status(400).json({ error: 'Missing dn or data' });
    
    const changes = [];
    const attrMap = {
        displayName: data.displayName, title: data.title, department: data.department, company: data.company,
        l: data.l, st: data.st, mail: data.mail, info: data.info,
        telephoneNumber: data.telephoneNumber, mobile: data.mobile, homePhone: data.homePhone,
        extensionAttribute1: data.sn, extensionAttribute2: data.givenName, extensionAttribute3: data.patronymic,
        assistant: data.assistant, description: data.description, physicalDeliveryOfficeName: data.office
    };
    
    for (const [k, v] of Object.entries(attrMap)) {
        if (v !== undefined && v !== null && v !== '') {
            changes.push({ operation: 'replace', modification: { [k]: v } });
        }
    }
    
    if (data.manager) {
        if (/^ваканс|^vacanc/i.test(data.manager)) {
            changes.push({ operation: 'replace', modification: { manager: '' } });
        } else {
            const mgrObj = cache.users.find(u => u.displayName === data.manager);
            if (mgrObj?.dn) changes.push({ operation: 'replace', modification: { manager: mgrObj.dn } });
        }
    }
    
    if (data.enabled !== undefined) {
        changes.push({ operation: 'replace', modification: { userAccountControl: data.enabled ? '512' : '514' } });
    }
    
    if (data.newOU && data.newOU !== dn.substring(dn.indexOf(',') + 1)) {
        // Move user - need to use moddn
        const newDN = `CN=${escapeDN(data.displayName || dn.split(',')[0].substring(3))},${data.newOU}`;
        try {
            const client = ldap.createClient({ url: req.session.adUrl, tlsOptions: { rejectUnauthorized: false } });
            await new Promise((resolve, reject) => {
                client.bind(req.session.adUser, req.session.adPass, (err) => {
                    if (err) { client.destroy(); return reject(err); }
                    client.modifyDN(dn, newDN.substring(0, newDN.indexOf(',')), data.newOU, (err2) => {
                        client.unbind();
                        if (err2) return reject(err2);
                        resolve();
                    });
                });
            });
            auditLog(req.session.adUser, 'MOVE', dn, { newOU: data.newOU });
            log(`MOVE V3: ${dn} → ${newDN}`);
        } catch(e) {
            log('MOVE ERROR V3: ' + e.message);
        }
        // Now modify the new DN
        try {
            ldapModify(req.session.adUrl, req.session.adUser, req.session.adPass, newDN, changes);
            auditLog(req.session.adUser, 'UPDATE', newDN, data);
            setTimeout(() => getADData(req.session.adUser, req.session.adPass, req.session.adUrl), 500);
            return res.json({ success: true });
        } catch(e) {
            return res.status(500).json({ error: sanitize(e.message, req.session.adPass) });
        }
    }
    
    try {
        ldapModify(req.session.adUrl, req.session.adUser, req.session.adPass, dn, changes);
        auditLog(req.session.adUser, 'UPDATE', dn, data);
        res.json({ success: true });
    } catch(e) {
        res.status(500).json({ error: sanitize(e.message, req.session.adPass) });
    }
});

// --- Bulk Operations ---
app.post('/api/batch-toggle', isAuth, async (req, res) => {
    const { dns, enabled } = req.body;
    if (!dns?.length) return res.status(400).json({ error: 'No DNs provided' });
    
    let success = 0, failed = 0;
    for (const dn of dns) {
        try {
            ldapModify(req.session.adUrl, req.session.adUser, req.session.adPass, dn, [
                { operation: 'replace', modification: { userAccountControl: enabled ? '512' : '514' } }
            ]);
            auditLog(req.session.adUser, enabled ? 'ENABLE' : 'DISABLE', dn, {});
            success++;
        } catch(e) { failed++; }
    }
    res.json({ success, failed });
            // Auto re-sync after changes
            if (success > 0) setTimeout(() => getADData(req.session.adUser, req.session.adPass, req.session.adUrl), 500);
});

// --- VPN Add ---
app.post('/api/vpn-add', isAuth, async (req, res) => {
    const { dn } = req.body;
    try {
        const vpnGroup = 'CN=AD_VPN_Users,OU=Service Groups,OU=Groups,DC=rusagroeco,DC=ru';
        ldapModify(req.session.adUrl, req.session.adUser, req.session.adPass, vpnGroup,
            [{ operation: 'add', modification: { member: dn } }]);
        auditLog(req.session.adUser, 'VPN_ADD', dn, {});
        res.json({ success: true });
    } catch(e) { res.status(500).json({ error: sanitize(e.message, req.session.adPass) }); }
});

// --- CSV Compare ---
app.post('/api/compare-csv', isAuth, (req, res) => {
    try {
        const csvBuf = req.body.isBase64 ? Buffer.from(req.body.csvData, 'base64') : req.body.csvData;
        const txt = iconv.decode(csvBuf, 'win1251');
        const raw = parse(txt, { columns: true, delimiter: ';', skip_empty_lines: true, relax_column_count: true, relax_quotes: true });
        const results = [];
        for (const r of raw) {
            const g = (k) => (r[k] || '').trim();
            let sn = g('Фамилия'), gn = g('Имя'), pn = g('Отчество'), fio = g('ФИО');
            let login = g('Логин');
            if (!login && sn) {
                login = tr(sn);
                if (gn) login += '.' + tr(gn)[0];
                if (pn) login += tr(pn)[0];
                login = login.toLowerCase().replace(/[^a-z0-9.]/g, '');
            }
            let siteOU = g('siteOU');
            if (!siteOU && g('Регион') && cache.ous?.length) {
                const region = g('Регион'), dept = g('Отдел');
                if (dept) {
                    const sameDept = cache.users.find(u => u.department === dept && u.dn);
                    if (sameDept) siteOU = sameDept.dn.replace(/^CN=[^,]+,/, '');
                }
                if (!siteOU) {
                    const ouMatch = cache.ous.find(o => o.dn.includes('OU=' + region) && o.dn.includes('OU=Users') && !/Special|Computers|Servers/i.test(o.dn));
                    if (ouMatch) siteOU = ouMatch.dn;
                }
            }
            const inc = {
                displayName: fio, sam: login, mail: g('Email'), title: g('Должность'),
                department: g('Отдел'), company: g('Компания'), st: g('Регион'), l: g('Город'),
                info: g('Дата_Рождения'), telephoneNumber: g('Рабочий_Тел'), mobile: g('Мобильный'),
                homePhone: g('Телефон'), sn, givenName: gn, patronymic: pn,
                assistant: g('Привязки'), enabled: (g('Активность') !== 'Нет' && g('Активность') !== '0'),
                description: g('Описание'), office: g('Адрес'), manager: g('Менеджер'), siteOU
            };
            // Match by: 1) sAMAccountName 2) displayName 3) email 4) email+displayName
            let ex = cache.users.find(u => u.sAMAccountName === inc.sam || (u.displayName === inc.displayName && inc.displayName));
            if (!ex && inc.mail && inc.displayName) {
                ex = cache.users.find(u => u.mail === inc.mail);
                if (!ex) ex = cache.users.find(u => u.mail === inc.mail && u.displayName === inc.displayName);
            }
            if (!ex && inc.info && inc.displayName) {
                // Match by birth date (DD.MM.YYYY) + displayName for duplicates
                const infoShort = inc.info.replace(/^0+/, '').replace(/\.0+/g, '.');
                ex = cache.users.find(u => u.info && u.displayName === inc.displayName && 
                    (u.info === inc.info || u.info.replace(/^0+/, '').replace(/\.0+/g, '.') === infoShort));
            }
            if (!ex) { results.push({ type: 'new', incoming: inc }); continue; }
            const diffs = {};
            const attrs = { title: 'title', department: 'department', company: 'company', l: 'l', st: 'st', info: 'info', mail: 'mail', telephoneNumber: 'telephoneNumber', mobile: 'mobile', homePhone: 'homePhone', sn: 'extensionAttribute1', givenName: 'extensionAttribute2', patronymic: 'extensionAttribute3', assistant: 'assistant', description: 'description', office: 'physicalDeliveryOfficeName', manager: 'manager' };
            for (const [key, attr] of Object.entries(attrs)) {
                let incVal = inc[key] || '';
                let exVal = ex[attr] || '';
                if (key === 'manager' && exVal?.includes('=')) {
                    const m = cache.users.find(u => u.dn === exVal);
                    exVal = m ? m.displayName : exVal;
                }
                if (incVal && incVal !== String(exVal)) diffs[key] = { old: exVal, new: incVal };
            }
            if (Object.keys(diffs).length > 0) results.push({ type: 'diff', incoming: inc, existing: ex, diffs });
            else results.push({ type: 'same', incoming: inc, existing: ex });
        }
        res.json({ success: true, results });
    } catch(e) { res.status(500).json({ success: false, error: e.message }); }
});

// --- Export CSV ---
app.get('/api/export-csv', isAuth, (req, res) => {
    let users = cache.users;
    const getMgrName = (dn) => {
        if (!dn) return '';
        const m = cache.users.find(u => u.dn === dn);
        return m ? m.displayName : dn;
    };
    if (req.query.active === 'true') users = users.filter(u => !(parseInt(u.userAccountControl) & 2));
    let csv = 'Активность;Фамилия;Имя;Отчество;ФИО;Логин;Email;Должность;Отдел;Компания;Регион;Город;Дата_Рождения;Телефон;Рабочий_Тел;Мобильный;Привязки;Описание;Адрес;Менеджер\n';
    for (const u of users) {
        const parts = (u.displayName||'').trim().split(/\s+/);
        const sn = u.sn || u.extensionAttribute1 || parts[0] || '';
        const gn = u.givenName || u.extensionAttribute2 || parts[1] || '';
        const pn = u.extensionAttribute3 || parts[2] || '';
        csv += `${(parseInt(u.userAccountControl)&2)?'Нет':'Да'};${sn};${gn};${pn};${u.displayName||''};${u.sAMAccountName||''};${u.mail||''};${u.title||''};${u.department||''};${u.company||''};${u.st||''};${u.l||''};${u.info||''};${u.homePhone||''};${u.telephoneNumber||''};${u.mobile||''};${u.assistant||''};${u.description||''};${u.physicalDeliveryOfficeName||''};${getMgrName(u.manager)}\n`;
    }
    res.setHeader('Content-Type', 'text/csv; charset=windows-1251');
    res.send(iconv.encode(csv, 'win1251'));
});

// --- Reports ---
app.get('/api/report/empty-attrs', isAuth, (req, res) => {
    const fields = ['mail', 'telephoneNumber', 'mobile', 'title', 'department', 'info', 'sn', 'givenName'];
    const results = [];
    for (const u of cache.users) {
        const empty = [];
        for (const f of fields) if (!u[f]) empty.push(f);
        if (empty.length) results.push({ name: u.displayName, sam: u.sAMAccountName, empty });
    }
    res.json(results);
});

app.get('/api/report/duplicates', isAuth, (req, res) => {
    const byName = {};
    for (const u of cache.users) {
        const key = (u.displayName||'').toLowerCase();
        if (!byName[key]) byName[key] = [];
        byName[key].push(u.sAMAccountName);
    }
    const dups = Object.entries(byName).filter(([k,v]) => v.length > 1).map(([k,v]) => ({ name: k, logins: v }));
    res.json(dups);
});

app.get('/api/audit', isAuth, (req, res) => {
    try {
        const rows = audit.prepare('SELECT * FROM audit ORDER BY id DESC LIMIT 200').all();
        res.json(rows);
    } catch(e) { res.json([]); }
});


// --- Global error handlers ---
process.on('uncaughtException', (err) => {
    console.error('UNCAUGHT:', err.message, err.stack);
    try { fs.appendFileSync('/opt/agro-user-manager-v3/logs/app.log', new Date().toISOString() + ' [CRASH] ' + err.message + '\n' + err.stack + '\n'); } catch(e) {}
});
process.on('unhandledRejection', (reason, promise) => {
    console.error('UNHANDLED REJECTION:', reason);
    try { fs.appendFileSync('/opt/agro-user-manager-v3/logs/app.log', new Date().toISOString() + ' [REJECTION] ' + reason + '\n'); } catch(e) {}
});

// --- Start ---
app.listen(PORT, '0.0.0.0', () => log('AD Manager V3.0 started on port ' + PORT));

// --- Apply Batch ---
app.post('/api/apply-batch', isAuth, async (req, res) => {
    const { actions } = req.body;
    if (!actions?.length) return res.status(400).json({ error: 'No actions' });
    let success = 0, failed = 0;
    for (const action of actions) {
        try {
            if (action.type === 'update' && action.dn) {
                const changes = [];
                const d = action.data || {};
                const attrMap = { displayName: d.displayName, title: d.title, department: d.department, company: d.company,
                    l: d.l, st: d.st, mail: d.mail, info: d.info, telephoneNumber: d.telephoneNumber, mobile: d.mobile,
                    homePhone: d.homePhone, extensionAttribute1: d.sn, extensionAttribute2: d.givenName, extensionAttribute3: d.patronymic,
                    assistant: d.assistant, description: d.description, physicalDeliveryOfficeName: d.office };
                for (const [k, v] of Object.entries(attrMap)) {
                    if (v) changes.push({ operation: 'replace', modification: { [k]: v } });
                }
                if (d.manager) {
                    if (/^ваканс|^vacanc/i.test(d.manager)) {
                        // Clear manager for vacancy positions
                        changes.push({ operation: 'replace', modification: { manager: '' } });
                    } else {
                        const mgrObj = cache.users.find(u => u.displayName === d.manager || u.dn === d.manager);
                        if (mgrObj?.dn) changes.push({ operation: 'replace', modification: { manager: mgrObj.dn } });
                    }
                }
                if (d.enabled !== undefined) {
                    changes.push({ operation: 'replace', modification: { userAccountControl: d.enabled ? '512' : '514' } });
                }
                if (changes.length) ldapModify(req.session.adUrl, req.session.adUser, req.session.adPass, action.dn, changes);
                auditLog(req.session.adUser, 'BATCH_UPDATE', action.dn, d);
            }
            if (action.type === 'create' && action.data) {
                const d = action.data;
                const sn = (d.sn || d.displayName?.split(/\s+/)[0] || '').trim();
                const gn = (d.givenName || d.displayName?.split(/\s+/)[1] || '').trim();
                const trSn = tr(sn).replace(/^./, c => c.toUpperCase());
                const trGn = tr(gn).replace(/^./, c => c.toUpperCase());
                let login = (d.sam || (tr(sn) + '.' + (tr(gn)[0]||'')).toLowerCase().replace(/[^a-z0-9.]/g, '')).trim();
                const siteOU = d.siteOU?.toUpperCase().startsWith('OU=USERS,') ? d.siteOU : `OU=Users,${d.siteOU}`;
                const userDN = `CN=${escapeDN(d.displayName)},${siteOU}`;
                const pass = `Agro${Math.random().toString(36).substring(2, 10)}!`;
                
                const entry = { cn: d.displayName, displayName: d.displayName, sn: trSn, givenName: trGn,
                    sAMAccountName: login, userPrincipalName: login + '@ahprostory.ru', 
                    objectClass: ['top', 'person', 'organizationalPerson', 'user'], userAccountControl: '514' };
                const attrs = { title: d.title, department: d.department, company: d.company, l: d.l, st: d.st,
                    mail: d.mail || (login + '@ahprostory.ru'), extensionAttribute1: sn, extensionAttribute2: gn,
                    extensionAttribute3: action.data.patronymic };
                for (const [k, v] of Object.entries(attrs)) if (v) entry[k] = v;
                
                // Check login uniqueness
            const existingLogin = cache.users.find(u => u.sAMAccountName === login);
            if (existingLogin) {
                log('CREATE V3: Login ' + login + ' already exists');
                return res.status(400).json({ success: false, error: 'Логин ' + login + ' уже занят (пользователь: ' + (existingLogin.displayName||existingLogin.sAMAccountName) + ')' });
            }
            ldapAdd(req.session.adUrl, req.session.adUser, req.session.adPass, userDN, entry);
                const pwdBase64 = Buffer.from(`"${pass}"`, 'utf16le').toString('base64');
                ldapModify(req.session.adUrl, req.session.adUser, req.session.adPass, userDN,
                    [{ operation: 'replace', modification: { unicodePwd: pwdBase64 } },
                     { operation: 'replace', modification: { userAccountControl: '512' } }]);
                auditLog(req.session.adUser, 'BATCH_CREATE', login, { displayName: d.displayName });
            }
            success++;
        } catch(e) { failed++; }
    }
    res.json({ success, failed });
            // Auto re-sync after changes
            if (success > 0) setTimeout(() => getADData(req.session.adUser, req.session.adPass, req.session.adUrl), 500);
});
