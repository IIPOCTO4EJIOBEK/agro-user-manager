<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - AD Manager Portal</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <div class="wrapper">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <h2><i class="fas fa-shield-alt"></i> AD Portal</h2>
        <p>v4.0</p>
      </div>
      
      <nav class="sidebar-nav">
        <a href="/dashboard" class="nav-item <%= typeof active !== 'undefined' && active === 'dashboard' ? 'active' : '' %>">
          <i class="fas fa-home"></i>
          <span>Главная</span>
        </a>
        <a href="/users" class="nav-item <%= typeof active !== 'undefined' && active === 'users' ? 'active' : '' %>">
          <i class="fas fa-users"></i>
          <span>Пользователи</span>
        </a>
        <a href="/wifi" class="nav-item <%= typeof active !== 'undefined' && active === 'wifi' ? 'active' : '' %>">
          <i class="fas fa-wifi"></i>
          <span>WiFi & SMS</span>
        </a>
        <a href="/monitoring" class="nav-item <%= typeof active !== 'undefined' && active === 'monitoring' ? 'active' : '' %>">
          <i class="fas fa-chart-line"></i>
          <span>Мониторинг</span>
        </a>
        <a href="/settings" class="nav-item <%= typeof active !== 'undefined' && active === 'settings' ? 'active' : '' %>">
          <i class="fas fa-cog"></i>
          <span>Настройки</span>
        </a>
      </nav>
      
      <div class="sidebar-footer">
        <div class="user-info">
          <i class="fas fa-user-circle"></i>
          <span><%= user?.sAMAccountName || 'Гость' %></span>
        </div>
        <a href="/logout" class="logout-btn">
          <i class="fas fa-sign-out-alt"></i>
        </a>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
      <header class="topbar">
        <h1><%= title %></h1>
        <div class="breadcrumbs">
          <span><%= new Date().toLocaleDateString('ru-RU') %></span>
        </div>
      </header>
      
      <div class="content">
        <%- body %>
      </div>
    </main>
  </div>

  <script src="/js/main.js"></script>
</body>
</html>
