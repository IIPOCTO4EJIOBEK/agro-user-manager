<%- include('../partials/header', { activePage: 'dashboard' }) %>
<div class="stats">
  <div class="stat"><div class="num" id="totalUsers">-</div><div class="lbl">Пользователей в AD</div></div>
  <div class="stat"><div class="num" id="enabledUsers">-</div><div class="lbl">Активных пользователей</div></div>
  <div class="stat"><div class="num" id="disabledUsers">-</div><div class="lbl">Отключенных пользователей</div></div>
  <div class="stat"><div class="num" id="totalGroups">-</div><div class="lbl">Групп безопасности</div></div>
</div>

<div class="row" style="grid-template-columns:repeat(auto-fit,minmax(240px,1fr))">
  <a href="/users" class="card" style="display:flex;align-items:center;gap:16px;text-decoration:none"><span style="font-size:32px">👤</span><div><b>Пользователи</b><br><span style="font-size:12px;color:var(--text-secondary)">Управление учётными записями</span></div></a>
  <a href="/wifi" class="card" style="display:flex;align-items:center;gap:16px;text-decoration:none"><span style="font-size:32px">📶</span><div><b>WiFi & SMS</b><br><span style="font-size:12px;color:var(--text-secondary)">Гостевая сеть и авторизация</span></div></a>
  <a href="/computers" class="card" style="display:flex;align-items:center;gap:16px;text-decoration:none"><span style="font-size:32px">🖥</span><div><b>Компьютеры</b><br><span style="font-size:12px;color:var(--text-secondary)">Устройства в домене</span></div></a>
  <a href="/groups" class="card" style="display:flex;align-items:center;gap:16px;text-decoration:none"><span style="font-size:32px">👥</span><div><b>Группы</b><br><span style="font-size:12px;color:var(--text-secondary)">Группы безопасности</span></div></a>
</div>

<div class="card"><h3>🔍 Быстрый поиск</h3><input type="text" id="qsearch" placeholder="Введите имя или логин..." onkeyup="if(event.key==='Enter')quickSearch()" style="width:100%;padding:12px;border:2px solid var(--border);border-radius:var(--radius-sm);font-size:14px"><div id="qresults" style="margin-top:8px"></div></div>
<div class="card"><h3>🕐 Последние действия</h3><div id="recentAudit">Загрузка...</div></div>

<div class="card">
  <h3>📡 Состояние системы</h3>
  <div id="systemStatus"><span class="spinner"></span> Загрузка...</div>
</div>

<script>
fetch('/api/monitoring/stats').then(function(r){return r.json()}).then(function(d){
  if(!d.success)return;
  document.getElementById('totalUsers').textContent = d.data.totalUsers;
  document.getElementById('enabledUsers').textContent = d.data.enabledUsers;
  document.getElementById('disabledUsers').textContent = d.data.disabledUsers;
  document.getElementById('totalGroups').textContent = d.data.totalGroups;
});
fetch('/api/settings/ldap-status').then(function(r){return r.json()}).then(function(d){
  var el = document.getElementById('systemStatus');
  if(d.success&&d.data.connected) el.innerHTML = '<span style="color:var(--success)">✅ LDAP подключен: ' + (d.data.domainName||'rusagroeco.ru') + '</span>';
  else el.innerHTML = '<span style="color:var(--danger)">❌ LDAP не подключен</span>';
}).catch(function(){document.getElementById('systemStatus').innerHTML = '<span style="color:var(--danger)">❌ Ошибка</span>';});
</script>
<%- include('../partials/footer') %>
