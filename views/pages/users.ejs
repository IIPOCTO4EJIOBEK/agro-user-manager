<%- include('../partials/header', { activePage: 'users' }) %>
<div class="card">
  <div class="row" style="margin-bottom:16px">
    <div class="fg">
      <input type="text" id="userSearch" placeholder="Поиск по имени, логину или email...">
    </div>
    <div><button class="btn btn-p" onclick="searchUsers()"><i class="fas fa-search"></i> Найти</button></div>
  </div>
  <div id="usersTableContainer" style="overflow-x:auto">
    <table><thead><tr><th>Имя</th><th>Логин</th><th>Email</th><th>Статус</th><th>Действия</th></tr></thead>
    <tbody id="usersTableBody"><tr><td colspan="5" style="text-align:center;padding:30px"><div class="spinner"></div> Загрузка...</td></tr></tbody></table>
  </div>
</div>
<script>
let curUsers=[];
function searchUsers(){var q=document.getElementById('userSearch').value;fetch('/api/users/list?query='+encodeURIComponent(q)).then(r=>r.json()).then(d=>{if(d.success){curUsers=d.data;renderUsers(curUsers);}}).catch(console.error);}
function renderUsers(u){var t=document.getElementById('usersTableBody');if(!u.length){t.innerHTML='<tr><td colspan="5" style="text-align:center;padding:30px;color:var(--text-secondary)">Пользователи не найдены</td></tr>';return;}
t.innerHTML=u.map(function(x){return '<tr><td><b>'+escapeHtml(x.cn||x.sAMAccountName)+'</b></td><td><code>'+escapeHtml(x.sAMAccountName)+'</code></td><td>'+(x.mail||'-')+'</td><td><span class="badge" style="background:'+(x.enabled?'var(--success-light);color:var(--success)':'var(--danger-light);color:var(--danger)')+'">'+(x.enabled?'Активен':'Отключен')+'</span></td><td><button class="btn btn-o btn-sm" onclick="viewUser("'+encodeURIComponent(x.dn)+'")"><i class="fas fa-eye"></i></button></td></tr>';}).join('');}
function escapeHtml(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function viewUser(dn){fetch('/api/users/'+dn).then(r=>r.json()).then(function(d){if(d.success){var u=d.data;alert('Пользователь: '+u.cn+'\nLogin: '+u.sAMAccountName+'\nEmail: '+u.mail+'\nГруппы: '+u.memberOf.join(', '));}}).catch(console.error);}
searchUsers();
</script>
<%- include('../partials/footer') %>
