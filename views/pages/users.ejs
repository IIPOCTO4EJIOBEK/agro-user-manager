<%- include('../partials/header', { activePage: 'users' }) %>
<div class="card">
  <div style="display:flex;gap:12px;margin-bottom:16px;flex-wrap:wrap">
    <div class="fg" style="flex:1;min-width:200px">
      <input type="text" id="userSearch" placeholder="Поиск по имени, логину или email..." onkeyup="if(event.key==='Enter')searchUsers()">
    </div>
    <div style="display:flex;gap:8px;align-items:flex-end">
      <button class="btn btn-p" onclick="searchUsers()">🔍 Искать</button>
      <button class="btn btn-g" onclick="showCreateUser()">➕ Создать</button>
      <a href="/users/disabled" class="btn btn-o">🔴 Отключенные</a>
    </div>
  </div>
  <div style="overflow-x:auto">
    <table><thead><tr><th>Имя</th><th>Логин</th><th>Email</th><th>Групп</th><th>Статус</th><th></th></tr></thead>
    <tbody id="usersTableBody"><tr><td colspan="6" style="text-align:center;padding:30px"><span class="spinner"></span></td></tr></tbody></table>
  </div>
</div>

<div class="modal-overlay" id="userModal"><div class="modal" id="userModalContent"></div></div>

<script>
var curUsers = [];
function searchUsers() {
  var q = document.getElementById('userSearch').value;
  fetch('/api/users/list?query='+encodeURIComponent(q)).then(function(r){return r.json()}).then(function(d){
    if(d.success){curUsers=d.data;renderUsers(curUsers);}
  });
}
function renderUsers(u){
  var t=document.getElementById('usersTableBody');
  if(!u||!u.length){t.innerHTML='<tr><td colspan="6" class="empty">Пользователи не найдены</td></tr>';return;}
  t.innerHTML = u.map(function(x){return '<tr>'+
    '<td><b>'+esc(x.cn||x.sAMAccountName)+'</b></td>'+
    '<td><code>'+esc(x.sAMAccountName)+'</code></td>'+
    '<td>'+(x.mail?esc(x.mail):'-')+'</td>'+
    '<td>'+(x.memberOf?x.memberOf.length:0)+'</td>'+
    '<td><span class="badge" style="background:'+(x.enabled?'var(--success-light);color:var(--success)':'var(--danger-light);color:var(--danger)')+'">'+(x.enabled?'Активен':'Отключен')+'</span></td>'+
    '<td style="white-space:nowrap">'+
      '<button class="btn btn-sm btn-o" onclick="viewUser("'+escAttr(x.dn)+'")" title="Просмотр">👁</button> '+
      '<button class="btn btn-sm '+(x.enabled?'btn-o" style="color:var(--danger);border-color:var(--danger)"':'btn-g')+'" onclick="toggleUser("'+escAttr(x.dn)+'",'+(+(!x.enabled))+')">'+(x.enabled?'🔴':'✅')+'</button> '+
      '<button class="btn btn-sm btn-o" onclick="showResetPwd("'+escAttr(x.dn)+'","'+escAttr(x.sAMAccountName)+'")" title="Сброс пароля">🔑</button>'+
    '</td></tr>';}).join('');
}
function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function escAttr(s){return String(s||'').replace(/"/g,'&quot;');}
function closeModal(){document.getElementById('userModal').style.display='none';}
function viewUser(dn){
  fetch('/api/users/'+encodeURIComponent(dn)).then(function(r){return r.json()}).then(function(d){
    if(!d.success)return;
    var u=d.data;
    document.getElementById('userModalContent').innerHTML='<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px"><h3>👤 '+esc(u.cn)+'</h3><button class="btn btn-sm btn-o" onclick="closeModal()">✕</button></div>'+
      '<div class="row"><div class="fg"><label>Логин</label><input value="'+esc(u.sAMAccountName)+'" readonly></div>'+
      '<div class="fg"><label>Email</label><div style="display:flex;gap:8px"><input value="'+esc(u.mail)+'" id="ed-mail"><button class="btn btn-sm btn-p" onclick="editUser("'+escAttr(u.dn)+'","mail")">💾</button></div></div></div>'+
      '<div class="row"><div class="fg"><label>Телефон</label><input value="'+esc(u.telephoneNumber||'')+'" id="ed-phone"></div>'+
      '<div class="fg"><label>Должность</label><input value="'+esc(u.title||'')+'" id="ed-title"></div></div>'+
      '<div class="fg"><label>Отдел</label><input value="'+esc(u.department||'')+'" id="ed-dept"></div>'+
      '<button class="btn btn-p" style="margin-top:16px" onclick="editUser("'+escAttr(u.dn)+'","all")">💾 Сохранить изменения</button>'+
      '<div class="fg" style="margin-top:16px"><label>Группы ('+u.memberOf.length+')</label></div>'+
      '<div style="max-height:200px;overflow-y:auto;border:1px solid var(--border);border-radius:var(--radius-sm);padding:8px;font-size:12px">'+
      (u.memberOf.length?u.memberOf.map(function(g){return '<div style="padding:4px 0;border-bottom:1px solid var(--border-light)">'+esc(g)+'</div>';}).join(''):'<div style="color:var(--text-secondary)">Нет групп</div>')+'</div>';
    document.getElementById('userModal').style.display='flex';
  });
}
function editUser(dn,field){
  var data={};
  if(field=='mail'||field=='all') data.mail=document.getElementById('ed-mail').value;
  if(field=='all'){data.telephoneNumber=document.getElementById('ed-phone').value;data.title=document.getElementById('ed-title').value;data.department=document.getElementById('ed-dept').value;}
  fetch('/api/users/'+encodeURIComponent(dn),{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)}).then(function(r){return r.json()}).then(function(d){if(d.success)alert('Сохранено');else alert('Ошибка: '+d.message);});
}
function toggleUser(dn,enable){
  if(!confirm(enable?'Включить?':'Отключить?'))return;
  fetch('/api/users/'+(enable?'enable':'disable')+'/'+encodeURIComponent(dn),{method:'PATCH'}).then(function(r){return r.json()}).then(function(d){if(d.success)searchUsers();else alert(d.message);});
}
function showResetPwd(dn,sam){
  var p=prompt('Новый пароль для '+sam+':','');
  if(!p||p.length<8){alert('Минимум 8 символов');return;}
  fetch('/api/password/reset',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({dn:dn,newPassword:p})}).then(function(r){return r.json()}).then(function(d){if(d.success)alert('Пароль сброшен');else alert('Ошибка: '+d.message);});
}
function showCreateUser(){
  document.getElementById('userModalContent').innerHTML='<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px"><h3>➕ Создать пользователя</h3><button class="btn btn-sm btn-o" onclick="closeModal()">✕</button></div>'+
    '<div class="row"><div class="fg"><label>Имя *</label><input id="cu-fn" placeholder="Иван"></div><div class="fg"><label>Фамилия *</label><input id="cu-ln" placeholder="Иванов"></div></div>'+
    '<div class="row"><div class="fg"><label>Логин *</label><input id="cu-sam" placeholder="ivanov.ii"></div><div class="fg"><label>Email</label><input id="cu-mail" placeholder="ivanov@company.ru"></div></div>'+
    '<div class="fg"><label>OU</label><input id="cu-ou" value="OU=Users,DC=rusagroeco,DC=ru"></div>'+
    '<div class="fg"><label>Пароль</label><input type="password" id="cu-pwd" placeholder="Минимум 8 символов"></div>'+
    '<div style="margin-top:16px;display:flex;gap:8px"><button class="btn btn-p" onclick="doCreateUser()">✅ Создать</button><button class="btn btn-o" onclick="closeModal()">Отмена</button></div>';
  document.getElementById('userModal').style.display='flex';
}
function doCreateUser(){
  var data={cn:document.getElementById('cu-fn').value+' '+document.getElementById('cu-ln').value,givenName:document.getElementById('cu-fn').value,sn:document.getElementById('cu-ln').value,sAMAccountName:document.getElementById('cu-sam').value,mail:document.getElementById('cu-mail').value,ou:document.getElementById('cu-ou').value,userPassword:document.getElementById('cu-pwd').value};
  if(!data.sAMAccountName||!data.cn||!data.userPassword){alert('Заполните обязательные поля');return;}
  fetch('/api/users',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)}).then(function(r){return r.json()}).then(function(d){if(d.success){alert('Создан');closeModal();searchUsers();}else alert('Ошибка: '+d.message);});
}
searchUsers();
</script>
<%- include('../partials/footer') %>
