<div class="page-content">
  <div class="page-header">
    <h2><i class="fas fa-users"></i> Управление пользователями AD</h2>
    <div class="search-box">
      <input type="text" id="userSearch" placeholder="Поиск пользователей..." />
      <button onclick="searchUsers()" class="btn btn-primary">
        <i class="fas fa-search"></i> Найти
      </button>
    </div>
  </div>

  <div class="users-table-container">
    <table class="users-table">
      <thead>
        <tr>
          <th>Имя</th>
          <th>Login</th>
          <th>Email</th>
          <th>Статус</th>
          <th>Действия</th>
        </tr>
      </thead>
      <tbody id="usersTableBody">
        <tr>
          <td colspan="5" class="loading">Загрузка...</td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

<script>
let currentUsers = [];

function searchUsers() {
  const query = document.getElementById('userSearch').value;
  fetch('/api/users/list?query=' + encodeURIComponent(query))
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        currentUsers = data.data;
        renderUsers(currentUsers);
      }
    })
    .catch(console.error);
}

function renderUsers(users) {
  const tbody = document.getElementById('usersTableBody');
  if (users.length === 0) {
    tbody.innerHTML = '<tr><td colspan="5">Пользователи не найдены</td></tr>';
    return;
  }

  tbody.innerHTML = users.map(user => `
    <tr>
      <td>${user.cn || user.sAMAccountName}</td>
      <td>${user.sAMAccountName}</td>
      <td>${user.mail || '-'}</td>
      <td>
        <span class="badge ${user.enabled ? 'badge-success' : 'badge-danger'}">
          ${user.enabled ? 'Активен' : 'Отключен'}
        </span>
      </td>
      <td>
        <button onclick="viewUser('${encodeURIComponent(user.dn)}')" class="btn btn-sm btn-info">
          <i class="fas fa-eye"></i>
        </button>
        <button onclick="toggleUser('${encodeURIComponent(user.dn)}', ${!user.enabled})" 
                class="btn btn-sm ${user.enabled ? 'btn-warning' : 'btn-success'}">
          <i class="fas fa-${user.enabled ? 'ban' : 'check'}"></i>
        </button>
      </td>
    </tr>
  `).join('');
}

function viewUser(dn) {
  fetch('/api/users/' + dn)
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        const user = data.data;
        alert(`Пользователь: ${user.cn}\\nLogin: ${user.sAMAccountName}\\nEmail: ${user.mail}\\nГруппы: ${user.memberOf.join(', ')}`);
      }
    })
    .catch(console.error);
}

function toggleUser(dn, enable) {
  const action = enable ? 'enable' : 'disable';
  if (!confirm(enable ? 'Включить пользователя?' : 'Отключить пользователя?')) return;
  
  fetch('/api/users/' + action + '/' + dn, { method: 'PATCH' })
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        searchUsers();
      } else {
        alert('Ошибка: ' + data.message);
      }
    })
    .catch(console.error);
}

// Initial load
searchUsers();
</script>
