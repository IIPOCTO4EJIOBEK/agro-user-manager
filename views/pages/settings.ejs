<%- include('../partials/header', { activePage: 'settings' }) %>
<div class="card">
  <h3><i class="fas fa-cog"></i> Настройки</h3>
  <div id="settingsContent"><div class="spinner"></div> Загрузка...</div>
</div>
<script>
fetch('/api/settings/ldap-status').then(r=>r.json()).then(function(d){var h='<div class="card"><h3><i class="fas fa-server"></i> LDAP подключение</h3>';if(d.success){h+='<p><span style="color:var(--success)"><i class="fas fa-check-circle"></i> Подключен</span></p><p>Сервер: '+d.data.server+'</p><p>Домен: '+d.data.domain+'</p>';}else{h+='<p><span style="color:var(--danger)"><i class="fas fa-exclamation-circle"></i> Ошибка: '+(d.data&&d.data.error||'Неизвестно')+'</span></p>';}h+='</div>';document.getElementById('settingsContent').innerHTML=h;}).catch(function(){document.getElementById('settingsContent').innerHTML='<p>Ошибка загрузки</p>';});
</script>
<%- include('../partials/footer') %>
