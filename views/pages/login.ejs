<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - AD Manager Portal</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="login-page">
  <div class="login-container">
    <div class="login-box">
      <div class="login-header">
        <i class="fas fa-shield-alt"></i>
        <h1>AD Manager Portal</h1>
        <p>Версия 4.0</p>
      </div>

      <% if (error) { %>
        <div class="alert alert-error">
          <i class="fas fa-exclamation-circle"></i>
          <%= error %>
        </div>
      <% } %>

      <form action="/login?returnTo=<%= returnTo %>" method="POST" class="login-form">
        <div class="form-group">
        <div class="form-group">
          <label for="adServer"><i class="fas fa-server"></i> Сервер AD</label>
          <select id="adServer" name="adServer" class="form-control">
            <option value="10.1.20.21">10.1.20.21 (основной)</option>
            <option value="10.0.2.21">10.0.2.21 (резервный)</option>
          </select>
        </div>
          <label for="username">
            <i class="fas fa-user"></i>
            Имя пользователя
          </label>
          <input 
            type="text" 
            id="username" 
            name="username" 
            placeholder="Имя пользователя" 
            required 
            autofocus
          >
        </div>

        <div class="form-group">
          <label for="password">
            <i class="fas fa-lock"></i>
            Пароль
          </label>
          <input 
            type="password" 
            id="password" 
            name="password" 
            placeholder="Введите пароль" 
            required
          >
        </div>

        <button type="submit" class="btn btn-primary btn-block">
          <i class="fas fa-sign-in-alt"></i>
          Войти
        </button>
      </form>

      <div class="login-footer">
        <p>&copy; 2026 AD Manager Portal. Все права защищены.</p>
      </div>
    </div>
  </div>
</body>
</html>
