<%- include('../partials/header', { activePage: 'groups' }) %>
<div class="card">
  <h3><i class="fas fa-users-cog"></i> Группы безопасности</h3>
  <div class="row" style="margin-bottom:16px">
    <div class="fg" style="flex:1"><input type="text" id="grp-search" placeholder="Поиск группы..." onkeyup="if(event.key==='Enter')loadGroups()"></div>
    <div><button class="btn btn-p btn-sm" onclick="loadGroups()"><i class="fas fa-search"></i> Поиск</button></div>
  </div>
  <div id="groups-list" style="max-height:500px;overflow:auto"><div class="spinner"></div> Загрузка...</div>
</div>
<script>
function loadGroups() {
  var q = document.getElementById('grp-search').value;
  document.getElementById('groups-list').innerHTML = '<div class="spinner"></div> Загрузка...';
  fetch('/api/groups?search='+encodeURIComponent(q)).then(function(r){return r.json()}).then(function(d){
    if(!d.success||!d.data){document.getElementById('groups-list').innerHTML='<div class="empty-state"><i class="fas fa-users-cog"></i><p>Нет данных</p></div>';return;}
    var html = '<table><tr><th>Название</th><th>Участников</th></tr>';
    d.data.forEach(function(g){
      html += '<tr><td><b>'+esc(g.cn)+'</b></td><td>'+(g.members?g.members.length:0)+'</td></tr>';
    });
    html += '</table>';
    document.getElementById('groups-list').innerHTML = html;
  }).catch(function(e){document.getElementById('groups-list').innerHTML='Ошибка: '+e.message;});
}
function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function showGroup(dn){
  fetch('/api/groups?search='+encodeURIComponent(dn.split(',')[0].replace('CN=',''))).then(function(r){return r.json()}).then(function(d){
    if(!d.success||!d.data)return;
    var grp=d.data.find(function(g){return g.dn===dn;});if(!grp)return;
    var h='<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px"><h3>👥 '+esc(grp.cn)+'</h3><button class="btn btn-sm btn-o" onclick="document.getElementById('grpModal').style.display='none'">✕</button></div>'+
      '<p style="margin-bottom:16px;color:var(--text-secondary)">Участников: '+(grp.members?grp.members.length:0)+'</p>'+
      '<div class="fg" style="margin-bottom:16px"><label>Добавить (DN)</label><div style="display:flex;gap:8px"><input id="grp-add-dn" placeholder="CN=..." style="flex:1"><button class="btn btn-sm btn-g" onclick="addMember(\''+escAttr(dn)+'\')">+</button></div></div>'+
      '<div style="max-height:300px;overflow:auto;border:1px solid var(--border);border-radius:var(--radius-sm)">'+
      (grp.members&&grp.members.length?'<table><tr><th>Участник</th><th></th></tr>'+grp.members.map(function(m){return '<tr><td style="font-size:12px">'+esc(m)+'</td><td><button style="background:var(--danger-light);color:var(--danger);border:none;cursor:pointer;padding:4px 8px;border-radius:4px" onclick="removeMember(\''+escAttr(dn)+'\',\''+escAttr(m)+'\')">✕</button></td></tr>';}).join('')+'</table>':'<div style="padding:20px;text-align:center;color:var(--text-secondary)">Нет участников</div>')+
      '</div>';
    document.getElementById('grpModalContent').innerHTML=h;document.getElementById('grpModal').style.display='flex';
  });
}
function addMember(dn){var m=document.getElementById('grp-add-dn').value.trim();if(!m)return;fetch('/api/groups/member',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({groupDn:dn,userDn:m})}).then(function(r){return r.json()}).then(function(d){if(d.success){showGroup(dn);loadGroups();}else alert(d.message);});}
function removeMember(dn,m){if(!confirm('Удалить?'))return;fetch('/api/groups/member',{method:'DELETE',headers:{'Content-Type':'application/json'},body:JSON.stringify({groupDn:dn,userDn:m})}).then(function(r){return r.json()}).then(function(d){if(d.success){showGroup(dn);loadGroups();}else alert(d.message);});}
// Override renderGroups to add button
var origRender = renderGroups;
renderGroups = function(d){
  if(!d.success||!d.data){document.getElementById('groups-list').innerHTML='<div class="empty-state"><i class="fas fa-users-cog"></i><p>Нет данных</p></div>';return;}
  var html='<table><tr><th>Название</th><th>Участников</th><th></th></tr>';
  d.data.forEach(function(g){
    html+='<tr><td><b>'+esc(g.cn)+'</b></td><td>'+(g.members?g.members.length:0)+'</td><td><button class="btn btn-sm btn-o" onclick="showGroup(\''+escAttr(g.dn)+'\')">👥</button></td></tr>';
  });
  html+='</table>';
  document.getElementById('groups-list').innerHTML=html;
};
loadGroups();
</script>
<div class="modal-overlay" id="grpModal"><div class="modal" id="grpModalContent"></div></div>
<%- include('../partials/footer') %>