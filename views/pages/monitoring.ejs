<%- include('../partials/header', { activePage: 'monitoring' }) %>
<div class="card">
  <h3><i class="fas fa-chart-line"></i> Мониторинг AD</h3>
  <div id="monStats" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px">
    <div class="stat-card"><div class="num" id="mTotal">-</div><div class="lbl">Всего пользователей</div></div>
    <div class="stat-card"><div class="num" id="mActive">-</div><div class="lbl">Активных</div></div>
    <div class="stat-card"><div class="num" id="mDisabled">-</div><div class="lbl">Отключенных</div></div>
    <div class="stat-card"><div class="num" id="mGroups">-</div><div class="lbl">Групп</div></div>
  </div>
</div>
<script>
fetch('/api/monitoring/stats').then(r=>r.json()).then(function(d){if(d.success){document.getElementById('mTotal').textContent=d.data.totalUsers;document.getElementById('mActive').textContent=d.data.enabledUsers;document.getElementById('mDisabled').textContent=d.data.disabledUsers;document.getElementById('mGroups').textContent=d.data.totalGroups;}}).catch(function(){});
</script>
<%- include('../partials/footer') %>
