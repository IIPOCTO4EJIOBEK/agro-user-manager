<%- include('../partials/header', { activePage: 'wifi' }) %>
<div class="card">
  <h3><i class="fas fa-wifi"></i> WiFi & SMS</h3>
  <p style="color:var(--text-secondary);margin-bottom:16px">Управление гостевой сетью WiFi и SMS-авторизацией</p>
  <div id="wifiStatus"><div class="spinner"></div> Загрузка...</div>
</div>
<script>
fetch('/api/wifi/stats').then(r=>r.json()).then(function(d){if(d.success){document.getElementById('wifiStatus').innerHTML='<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px"><div class="stat-card"><div class="num">'+(d.data.activeSessions||0)+'</div><div class="lbl">Активные сессии</div></div><div class="stat-card"><div class="num">'+(d.data.bindings||0)+'</div><div class="lbl">IP Bindings</div></div></div>';}}).catch(function(){document.getElementById('wifiStatus').innerHTML='<p style="color:var(--text-secondary)">Модуль WiFi ожидает настройки</p>';});
</script>
<%- include('../partials/footer') %>
