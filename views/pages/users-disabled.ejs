<%- include('../partials/header', { activePage: 'users' }) %>
<div class="card">
  <h3><i class="fas fa-user-slash"></i> Отключенные пользователи</h3>
  <div id="disabled-list"><div class="spinner"></div> Загрузка...</div>
</div>
<script>
fetch('/api/users-disabled').then(function(r){return r.json()}).then(function(d){
  if(!d.success||!d.data){document.getElementById('disabled-list').innerHTML='<div class="empty-state"><i class="fas fa-user-slash"></i><p>Нет данных</p></div>';return;}
  var html='<table><tr><th>Имя</th><th>Логин</th><th>Email</th></tr>';
  d.data.forEach(function(u){html+='<tr><td><b>'+esc(u.cn||u.sAMAccountName)+'</b></td><td><code>'+esc(u.sAMAccountName)+'</code></td><td>'+(u.mail||'-')+'</td></tr>';});
  html+='</table><p style="margin-top:12px;color:var(--text-secondary);font-size:12px">Всего: '+d.data.length+' отключенных</p>';
  document.getElementById('disabled-list').innerHTML=html;
}).catch(function(e){document.getElementById('disabled-list').innerHTML='Ошибка: '+e.message;});
function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
</script>
<%- include('../partials/footer') %>