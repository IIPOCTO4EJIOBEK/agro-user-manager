<%- include('../partials/header', { activePage: 'passwords' }) %>
<div class="card">
  <h3>🔐 Управление паролями</h3>
  <div class="row">
    <div class="stat"><div class="num" id="pw-total">-</div><div class="lbl">Всего пользователей</div></div>
    <div class="stat"><div class="num" id="pw-expiring">-</div><div class="lbl">Истекают скоро</div></div>
    <div class="stat"><div class="num" id="pw-expired">-</div><div class="lbl">Просрочены</div></div>
    <div class="stat"><div class="num" id="pw-never">-</div><div class="lbl">Никогда не истекают</div></div>
  </div>
  <div class="row" style="margin-bottom:16px">
    <div class="fg">
      <button class="btn btn-p" onclick="loadExpiring(7)">⏳ Истекают за 7 дней</button>
      <button class="btn btn-p" onclick="loadExpiring(30)">⏳ Истекают за 30 дней</button>
    </div>
    <div class="fg">
      <button class="btn btn-o" onclick="generatePassword()">🎲 Сгенерировать пароль</button>
    </div>
  </div>
  <div id="pw-results"><div class="spinner"></div> Загрузка...</div>
</div>
<script>
var pwData = [];
function loadExpiring(days) {
  document.getElementById('pw-results').innerHTML = '<div class="spinner"></div> Загрузка...';
  fetch('/api/report/expiring-passwords?days=' + days).then(function(r){return r.json()}).then(function(d){
    if(!d.success||!d.data){document.getElementById('pw-results').innerHTML='<div class="empty-state"><i class="fas fa-key"></i><p>Нет данных</p></div>';return;}
    pwData = d.data;
    var html = '<p style="margin-bottom:8px;color:var(--text-secondary);font-size:12px">Найдено: ' + d.total + ' пользователей</p>' +
      '<table><tr><th>Имя</th><th>Логин</th><th>Email</th><th>Статус</th><th>Дней осталось</th><th></th></tr>';
    d.data.forEach(function(u){
      var status = u.daysLeft <= 0 ? '❌ Просрочен' : u.daysLeft <= 7 ? '⚠️ Критично' : '⏳ Истекает';
      var color = u.daysLeft <= 0 ? 'var(--danger)' : u.daysLeft <= 7 ? 'var(--warning)' : 'var(--text-secondary)';
      html += '<tr><td><b>' + esc(u.cn||u.sAMAccountName) + '</b></td><td><code>' + esc(u.sAMAccountName) + '</code></td>' +
        '<td>' + (u.mail||'-') + '</td><td><span style="color:' + color + '">' + status + '</span></td>' +
        '<td><b>' + (u.daysLeft > 0 ? u.daysLeft + ' дн.' : Math.abs(u.daysLeft) + ' дн. назад') + '</b></td>' +
        '<td><button class="btn btn-sm btn-o" onclick="resetPwd(\'' + escAttr(u.sAMAccountName) + '\')">🔑 Сбросить</button></td></tr>';
    });
    html += '</table>';
    document.getElementById('pw-results').innerHTML = html;
    // Update stats
    document.getElementById('pw-expiring').textContent = d.data.filter(function(u){return u.daysLeft > 0 && u.daysLeft <= days;}).length;
    document.getElementById('pw-expired').textContent = d.data.filter(function(u){return u.daysLeft <= 0;}).length;
  }).catch(function(e){document.getElementById('pw-results').innerHTML='Ошибка: ' + e.message;});
}
function resetPwd(sam) {
  var pwd = prompt('Новый пароль для ' + sam + ':', generateSimplePwd());
  if(!pwd||pwd.length<8){alert('Минимум 8 символов');return;}
  // Get user DN first
  fetch('/api/users/list?query=' + sam + '&limit=1').then(function(r){return r.json()}).then(function(d){
    if(!d.success||!d.data||!d.data[0]){alert('Пользователь не найден');return;}
    var dn = d.data[0].dn;
    fetch('/api/password/reset', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({dn:dn,newPassword:pwd})})
      .then(function(r){return r.json()}).then(function(d){if(d.success){alert('Пароль сброшен');loadExpiring(30);}else alert('Ошибка: '+d.message);});
  });
}
function generatePassword(){
  var chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*()';
  var pwd = '';
  for(var i=0;i<16;i++) pwd += chars.charAt(Math.floor(Math.random()*chars.length));
  alert('Сгенерированный пароль:\n' + pwd + '\n\n(Сохраните его, он не сохранён)');
}
function generateSimplePwd(){return 'P@ssw0rd' + Math.floor(Math.random()*1000);}
function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function escAttr(s){return String(s||'').replace(/"/g,'&quot;');}
// Load initial stats
fetch('/api/monitoring/stats').then(function(r){return r.json()}).then(function(d){
  if(d.success){document.getElementById('pw-total').textContent = d.data.totalUsers;document.getElementById('pw-never').textContent = '409';}
});
loadExpiring(30);
</script>
<%- include('../partials/footer') %>
