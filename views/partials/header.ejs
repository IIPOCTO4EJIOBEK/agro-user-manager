<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - AD Manager Portal</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <header>
    <h1><i class="fas fa-shield-alt"></i> AD Manager Portal</h1>
    <div class="user-info">
      <span><i class="fas fa-user"></i> <%= user?.sAMAccountName || 'Гость' %></span>
      <a href="/logout"><i class="fas fa-sign-out-alt"></i> Выйти</a>
    </div>
  </header>
  <nav>
    <a href="/dashboard" class="<%= activePage === 'dashboard' ? 'active' : '' %>"><i class="fas fa-tachometer-alt"></i> Дашборд</a>
    <a href="/users" class="<%= activePage === 'users' ? 'active' : '' %>"><i class="fas fa-users"></i> Пользователи</a>
    <a href="/wifi" class="<%= activePage === 'wifi' ? 'active' : '' %>"><i class="fas fa-wifi"></i> WiFi & SMS</a>
    <a href="/monitoring" class="<%= activePage === 'monitoring' ? 'active' : '' %>"><i class="fas fa-chart-line"></i> Мониторинг</a>
    <a href="/settings" class="<%= activePage === 'settings' ? 'active' : '' %>"><i class="fas fa-cog"></i> Настройки</a>
  </nav>
