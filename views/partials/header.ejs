<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — AD Manager</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script>if(localStorage.getItem("theme")==="dark")document.body.classList.add("dark");</script>
</head>
<body>
<header>
  <h1><i class="fas fa-shield-alt"></i> AD Manager</h1>
  <div class="user-info">
    <span><i class="fas fa-user"></i> <%= user?.sAMAccountName || 'Гость' %></span>
    <button onclick="document.body.classList.toggle('dark');localStorage.setItem('theme',document.body.classList.contains('dark')?'dark':'light')" style="background:none;border:none;color:#fff;cursor:pointer;font-size:16px" title="Тёмная тема"><i class="fas fa-moon"></i></button>
    <a href="/logout"><i class="fas fa-sign-out-alt"></i> Выйти</a>
  </div>
</header>
<nav>
  <a href="/dashboard" class="<%= activePage === 'dashboard' ? 'active' : '' %>">📊 Дашборд</a>
  <a href="/users" class="<%= activePage === 'users' ? 'active' : '' %>">👤 Пользователи</a>
  <a href="/ous" class="<%= activePage === 'ous' ? 'active' : '' %>">📂 OU</a>
  <a href="/groups" class="<%= activePage === 'groups' ? 'active' : '' %>">👥 Группы</a>
  <a href="/computers" class="<%= activePage === 'computers' ? 'active' : '' %>">🖥 Компьютеры</a>
  <a href="/wifi" class="<%= activePage === 'wifi' ? 'active' : '' %>">📶 WiFi</a>
  <a href="/sms-auth" class="<%= activePage === 'sms-auth' ? 'active' : '' %>">📱 SMS</a>
  <a href="/monitoring" class="<%= activePage === 'monitoring' ? 'active' : '' %>">📈 Мониторинг</a>
  <a href="/reports" class="<%= activePage === 'reports' ? 'active' : '' %>">📋 Отчёты</a>
  <a href="/import" class="<%= activePage === 'import' ? 'active' : '' %>">📦 Импорт</a>
  <a href="/audit" class="<%= activePage === 'audit' ? 'active' : '' %>">📝 Аудит</a>
  <a href="/settings" class="<%= activePage === 'settings' ? 'active' : '' %>">⚙️ Настройки</a>
</nav>
<main>
