<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - AD Manager Portal</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<script>if(localStorage.getItem("theme")==="dark")document.body.classList.add("dark");</script>
</head>
<body>
  <header>
    <h1><i class="fas fa-shield-alt"></i> AD Manager Portal</h1>
    <div class="user-info">
      <span><i class="fas fa-user"></i> <%= user?.sAMAccountName || 'Гость' %></span>
      <a href="/logout"><i class="fas fa-sign-out-alt"></i> Выйти</a>
    </div>
  </header>
  <button onclick="document.body.classList.toggle('dark');localStorage.setItem('theme',document.body.classList.contains('dark')?'dark':'light')" style="background:none;border:none;color:rgba(255,255,255,0.8);cursor:pointer;font-size:18px;padding:0 16px" title="Тёмная тема"><i class="fas fa-moon"></i></button>
  <nav>
    <a href="/dashboard" class="<%= activePage === 'dashboard' ? 'active' : '' %>"><i class="fas fa-tachometer-alt"></i> Дашборд</a>
    <a href="/users" class="<%= activePage === 'users' ? 'active' : '' %>"><i class="fas fa-users"></i> Пользователи</a>
    <a href="/wifi" class="<%= activePage === 'wifi' ? 'active' : '' %>"><i class="fas fa-wifi"></i> WiFi & SMS</a>
    <a href="/monitoring" class="<%= activePage === 'monitoring' ? 'active' : '' %>"><i class="fas fa-chart-line"></i> Мониторинг</a>
    <a href="/sms-auth" class="<%= activePage === 'sms-auth' ? 'active' : '' %>"><i class="fas fa-sms"></i> SMS Авторизация</a>
    <a href="/users/disabled" class="<%= activePage === 'users' ? 'active' : '' %>"><i class="fas fa-user-slash"></i> Отключенные</a>
    <a href="/ous" class="<%= activePage === 'ous' ? 'active' : '' %>"><i class="fas fa-sitemap"></i> OU-структура</a>
    <a href="/groups" class="<%= activePage === 'groups' ? 'active' : '' %>"><i class="fas fa-users-cog"></i> Группы</a>
    <a href="/computers" class="<%= activePage === 'computers' ? 'active' : '' %>"><i class="fas fa-desktop"></i> Компьютеры</a>
    <a href="/reports" class="<%= activePage === 'reports' ? 'active' : '' %>"><i class="fas fa-chart-bar"></i> Отчёты</a>
    <a href="/import" class="<%= activePage === 'import' ? 'active' : '' %>"><i class="fas fa-file-import"></i> Импорт/Экспорт</a>
    <a href="/audit" class="<%= activePage === 'audit' ? 'active' : '' %>"><i class="fas fa-history"></i> Аудит</a>
    <a href="/settings" class="<%= activePage === 'settings' ? 'active' : '' %>"><i class="fas fa-cog"></i> Настройки</a>
  </nav>
  <main>
