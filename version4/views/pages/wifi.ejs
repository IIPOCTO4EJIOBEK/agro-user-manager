      <div class="card-title">Vouchers Today</div>
      <div class="card-value">127</div>
      <div class="card-change positive">
        <span>Generated today</span>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <div class="card-icon warning">📨</div>
      </div>
      <div class="card-title">SMS Sent</div>
      <div class="card-value">8,934</div>
      <div class="card-change positive">
        <span>Total this month</span>
      </div>
    </div>
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px;">
    <div style="padding: 24px; background: linear-gradient(135deg, #4f46e5, #7c3aed); border-radius: 16px; color: white;">
      <h3 style="font-size: 18px; margin-bottom: 8px;">Generate WiFi Voucher</h3>
      <p style="font-size: 14px; opacity: 0.9; margin-bottom: 20px;">Create access code for guest network</p>
      
      <div style="display: flex; gap: 8px; margin-bottom: 16px;">
        <select style="flex: 1; padding: 10px; border: none; border-radius: 8px; font-size: 14px;">
          <option>1 Hour</option>
          <option>4 Hours</option>
          <option selected>24 Hours</option>
          <option>7 Days</option>
        </select>
        <select style="flex: 1; padding: 10px; border: none; border-radius: 8px; font-size: 14px;">
          <option>10 Mbps</option>
          <option selected>50 Mbps</option>
          <option>100 Mbps</option>
        </select>
      </div>

      <button class="btn" style="background: white; color: #4f46e5; width: 100%;">
        Generate Voucher
      </button>
    </div>

    <div style="padding: 24px; background: #f8fafc; border-radius: 16px; border: 2px solid #e2e8f0;">
      <h3 style="font-size: 18px; margin-bottom: 8px; color: #1e293b;">Send SMS Code</h3>
      <p style="font-size: 14px; color: #64748b; margin-bottom: 20px;">Direct SMS authentication</p>
      
      <div style="margin-bottom: 16px;">
        <input 
          type="text" 
          placeholder="+7 (___) ___-__-__" 
          style="width: 100%; padding: 12px; border: 2px solid #e2e8f0; border-radius: 10px; font-size: 15px;"
        >
      </div>

      <button class="btn btn-primary" style="width: 100%;">
        Send SMS Code
      </button>
    </div>
  </div>

