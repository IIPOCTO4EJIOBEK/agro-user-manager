# Server Configuration
PORT=3000
NODE_ENV=development

# LDAP/Active Directory Settings
LDAP_URL=ldap://dc.example.com:389
LDAP_BASE_DN=DC=example,DC=com
LDAP_BIND_DN=CN=ServiceAccount,OU=Service Accounts,DC=example,DC=com
LDAP_BIND_PASSWORD=YourPasswordHere

# AD Groups for RBAC (CN names)
AD_GROUP_ADMINS=AD Administrators
AD_GROUP_NETWORK=Network Administrators  
AD_GROUP_MONITOR=Monitoring Group
AD_GROUP_WIFI=WiFi Managers

# Session Configuration
SESSION_SECRET=your-super-secret-session-key-change-in-production
SESSION_TIMEOUT=3600000

# Redis (optional for session storage)
REDIS_HOST=localhost
REDIS_PORT=6379

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
