# ============================================================================
# MYSQL CONFIGURATION - FIXED & OPTIMIZED
# Сервер: 10.0.1.200 (Primary)
# Назначение: Основная БД Bitrix24
# ============================================================================

[mysqld]
# ОСНОВНЫЕ НАСТРОЙКИ
user                    = mysql
pid-file                = /var/run/mysqld/mysqld.pid
socket                  = /var/run/mysqld/mysqld.sock
port                    = 3306
basedir                 = /usr
datadir                 = /var/lib/mysql
tmpdir                  = /tmp
bind-address            = 0.0.0.0
skip-external-locking

# ЛИМИТЫ ПОДКЛЮЧЕНИЙ
max_connections         = 2000
max_connect_errors      = 100000
wait_timeout            = 28800
interactive_timeout     = 28800

# КЭШИРОВАНИЕ И БУФЕРЫ (ОПТИМИЗИРОВАНО ДЛЯ 128GB RAM)
innodb_buffer_pool_size = 100G
innodb_buffer_pool_instances = 8
innodb_log_file_size    = 2G
innodb_log_buffer_size  = 256M
innodb_flush_log_at_trx_commit = 2
innodb_flush_method     = O_DIRECT
innodb_io_capacity      = 2000
innodb_io_capacity_max  = 4000
innodb_read_io_threads  = 8
innodb_write_io_threads = 8

# ЖУРНАЛЫ И ЛОГИРОВАНИЕ (ИСПРАВЛЕНО)
log_error               = /var/log/mysql/error.log
slow_query_log          = 1
slow_query_log_file     = /var/log/mysql/slow.log
long_query_time         = 2
log_queries_not_using_indexes = 1
log_slow_admin_statements = 1
log_slow_slave_statements = 1
min_examined_row_limit  = 1000

# РЕПЛИКАЦИЯ
server-id               = 1
log_bin                 = /var/log/mysql/mysql-bin.log
binlog_format           = ROW
binlog_expire_logs_seconds = 604800
max_binlog_size         = 100M
sync_binlog             = 1
relay_log               = /var/log/mysql/mysql-relay-bin.log
relay_log_recovery      = 1
read_only               = 0

# INNODB НАСТРОЙКИ
innodb_file_per_table   = 1
innodb_status_file      = 1
innodb_monitor_enable   = ALL
innodb_print_all_deadlocks = 1
innodb_lock_wait_timeout = 50
innodb_rollback_on_timeout = 0
innodb_autoinc_lock_mode = 2
innodb_checksum_algorithm = crc32
innodb_checksums        = 1

# MYISAM (если используется)
key_buffer_size         = 256M
myisam_sort_buffer_size = 128M

# TEMP TABLES
tmp_table_size          = 512M
max_heap_table_size     = 512M

# SORT BUFFERS
sort_buffer_size        = 4M
read_buffer_size        = 2M
read_rnd_buffer_size    = 8M
join_buffer_size        = 4M

# THREAD CACHE
thread_cache_size       = 100
thread_stack            = 512K

# QUERY CACHE (отключен в MySQL 8.0)
# query_cache_type      = 0
# query_cache_size      = 0

# CHARACTER SET
character-set-server    = utf8mb4
collation-server        = utf8mb4_unicode_ci

# SECURITY
local_infile            = 0
symbolic-links          = 0

# PERFORMANCE SCHEMA
performance_schema      = ON
performance_schema_instrument = '%=on'

# BINLOG CACHE
binlog_cache_size       = 32K
binlog_stmt_cache_size  = 32K

# GROUP REPLICATION (если нужно)
# gtid_mode = ON
# enforce_gtid_consistency = ON

[mysqldump]
quick
quote-names
max_allowed_packet      = 256M
single-transaction

[mysql]
default-character-set   = utf8mb4

[client]
port                    = 3306
socket                  = /var/run/mysqld/mysqld.sock
default-character-set   = utf8mb4
