```gitignore
# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Dependencies
node_modules/
package-lock.json

# Logs and temp files
*.log
*.tmp

# Environment files
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Coverage reports
coverage/
htmlcov/
.coverage

# Build outputs
dist/
build/
target/
```