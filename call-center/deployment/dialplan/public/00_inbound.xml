<include>
  <!-- Incoming calls → callcenter queue 500 (round-robin) -->
  <extension name="inbound_callcenter">
    <condition field="destination_number" expression="^(.*)$">
      <action application="answer"/>
      <action application="sleep" data="1000"/>
      <action application="callcenter" data="500@10.1.17.124"/>
    </condition>
  </extension>
</include>
